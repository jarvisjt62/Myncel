# ============================================================
#  Sentinel — Production Environment Variables
#  Copy to .env.production and fill in your values
#  NEVER commit .env.production to git!
# ============================================================

# ── App ──────────────────────────────────────────────────
NODE_ENV=production

# Your live domain (with https:// once SSL is set up)
# Before SSL: http://147.93.40.212
# After SSL:  https://yourdomain.com
NEXTAUTH_URL=https://yourdomain.com

# Random secret for JWT signing — generate with:
# openssl rand -base64 32
NEXTAUTH_SECRET=replace_with_64_char_random_string

# ── Database ─────────────────────────────────────────────
# PostgreSQL connection string
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
DATABASE_URL="postgresql://sentinel_user:YOUR_DB_PASSWORD@localhost:5432/sentinel_db?schema=public"

# ── Email (Hostinger SMTP) ───────────────────────────────
# Create a professional email in Hostinger hPanel:
# hPanel → Emails → Email Accounts → Create
# e.g. noreply@yourdomain.com
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=noreply@yourdomain.com
SMTP_PASS=your_email_account_password
SMTP_FROM="Sentinel <noreply@yourdomain.com>"

# ── Stripe (add when ready for billing) ──────────────────
# Get keys from https://dashboard.stripe.com/apikeys
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...

# ── Optional: Sentry Error Tracking ─────────────────────
# SENTRY_DSN=https://...@sentry.io/...
# NEXT_PUBLIC_SENTRY_DSN=https://...@sentry.io/...

# ── Optional: Analytics ──────────────────────────────────
# NEXT_PUBLIC_GA_MEASUREMENT_ID=G-...
# NEXT_PUBLIC_POSTHOG_KEY=phc_...