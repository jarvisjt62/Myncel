# ============================================================
#  Myncel — Environment Variables Reference
#  Copy this file to .env.local for local development
#  Add these variables to your Vercel project settings for production
# ============================================================

# ─────────────────────────────────────────
# App
# ─────────────────────────────────────────
NODE_ENV=development
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=dev-secret-change-in-production
# Generate a strong secret with: openssl rand -base64 32

# ─────────────────────────────────────────
# Database (Vercel Postgres recommended)
# ─────────────────────────────────────────
# Sign up at https://vercel.com/storage/postgres
# After creating, copy the connection string:
DATABASE_URL="postgresql://user:password@host:port/database?schema=public"

# Optional: Prisma Accelerate / Direct URL
POSTGRES_PRISMA_URL=
POSTGRES_URL_NON_POOLING=

# ─────────────────────────────────────────
# Email (SMTP)
# ─────────────────────────────────────────
SMTP_HOST=smtp.resend.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=resend
SMTP_PASS=your_resend_api_key_here
SMTP_FROM="Myncel <noreply@yourdomain.com>"

# ─────────────────────────────────────────
# Stripe — Credit/Debit Card Payments
# ─────────────────────────────────────────
# 1. Sign up at https://dashboard.stripe.com/register
# 2. Go to Developers > API Keys
# 3. Copy your keys (use test keys for dev, live keys for production)

STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Webhook secret — get this after running:
#   stripe listen --forward-to localhost:3000/api/webhooks/stripe
# Or from Stripe Dashboard > Webhooks > Add endpoint
STRIPE_WEBHOOK_SECRET=whsec_...

# ── Stripe Price IDs ──────────────────────────────────────────
# Create products + prices in Stripe Dashboard > Products
# Or use the Stripe CLI: stripe products create --name "Myncel Starter"

# Starter Plan ($49/mo or $39/mo billed annually)
STRIPE_PRICE_STARTER_MONTHLY=price_...
STRIPE_PRICE_STARTER_YEARLY=price_...

# Growth Plan ($99/mo or $79/mo billed annually)
STRIPE_PRICE_GROWTH_MONTHLY=price_...
STRIPE_PRICE_GROWTH_YEARLY=price_...

# Professional Plan ($249/mo or $199/mo billed annually)
STRIPE_PRICE_PROFESSIONAL_MONTHLY=price_...
STRIPE_PRICE_PROFESSIONAL_YEARLY=price_...

# ─────────────────────────────────────────
# PayPal — PayPal Account Payments
# ─────────────────────────────────────────
# 1. Sign up at https://developer.paypal.com
# 2. Go to My Apps & Credentials > Create App
# 3. Copy Client ID and Secret (use Sandbox for dev)

PAYPAL_CLIENT_ID=AYour_PayPal_Client_ID_Here
PAYPAL_CLIENT_SECRET=EYour_PayPal_Client_Secret_Here

# Set to "live" for production, "sandbox" for testing
PAYPAL_MODE=sandbox

# ── PayPal Subscription Plan IDs ─────────────────────────────
# Create subscription plans in PayPal Developer Dashboard
# or via the PayPal API. These are optional — if not set,
# Myncel will fall back to one-time PayPal orders.

PAYPAL_PLAN_STARTER_MONTHLY=P-...
PAYPAL_PLAN_STARTER_YEARLY=P-...
PAYPAL_PLAN_GROWTH_MONTHLY=P-...
PAYPAL_PLAN_GROWTH_YEARLY=P-...
PAYPAL_PLAN_PROFESSIONAL_MONTHLY=P-...
PAYPAL_PLAN_PROFESSIONAL_YEARLY=P-...

# ─────────────────────────────────────────
# Apple Pay / Google Pay
# ─────────────────────────────────────────
# These are automatically enabled through Stripe.
# No additional keys needed — just ensure Stripe is configured above.
# Apple Pay requires domain verification in Stripe Dashboard.
# Google Pay works automatically with Stripe on supported browsers.

# ─────────────────────────────────────────
# ACH / Bank Transfer
# ─────────────────────────────────────────
# ACH direct debit is handled automatically by Stripe.
# Enable it in: Stripe Dashboard > Settings > Payment Methods > ACH Direct Debit
# No additional environment variables needed.