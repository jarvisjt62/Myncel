# ============================================================
#  Sentinel — Vercel Local Development
#  Use this for local dev, or copy to Vercel environment variables
# ============================================================

# App
NODE_ENV=development
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=dev-secret-change-in-production

# Database (Vercel Postgres recommended)
# Sign up for Vercel Postgres: https://vercel.com/storage/postgres
# After creating, copy the connection string:
DATABASE_URL="postgresql://user:password@host:port/database?schema=public"

# Email (Hostinger SMTP or free替代: SendGrid Mailgun)
SMTP_HOST=smtp.resend.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=resend
SMTP_PASS=your_api_key_here
SMTP_FROM="Sentinel <noreply@yourdomain.com>"

# Optional: Stripe
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...

# Optional: Vercel Postgres Direct URL (for Prisma Accelerate)
POSTGRES_PRISMA_URL=
POSTGRES_URL_NON_POOLING=